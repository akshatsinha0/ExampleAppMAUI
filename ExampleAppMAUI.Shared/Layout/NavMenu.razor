<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="@AppNavigationRoutes.Home">@AppNavigationText.BrandName</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="@AppNavigationRoutes.Home" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> @AppNavigationText.Home
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="@AppNavigationRoutes.Todos">
                <span class="bi bi-plus-square-fill-nav-menu" aria-hidden="true"></span> @AppNavigationText.Todos
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="@AppNavigationRoutes.Counter">
                <span class="bi bi-plus-square-fill-nav-menu" aria-hidden="true"></span> @AppNavigationText.Counter
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="@AppNavigationRoutes.Weather">
                <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> @AppNavigationText.Weather
            </NavLink>
        </div>
    </nav>
</div>

