@page "/settings"

<PageTitle>@SettingsText.PageTitle</PageTitle>

<main class="settings-page">
    <header class="settings-header">
        <h1>@SettingsText.PageTitle</h1>
        <p>@AppIdentityText.Tagline</p>
    </header>

    <section class="settings-list" aria-label="@SettingsText.PageTitle">
        <article class="settings-item">
            <h2>@SettingsText.ThemeTitle</h2>
            <p>@SettingsText.ThemeDescription</p>
        </article>

        <article class="settings-item">
            <h2>@SettingsText.FontTitle</h2>
            <p>@SettingsText.FontDescription</p>
        </article>

        <article class="settings-item">
            <h2>@SettingsText.DataTitle</h2>
            <p>@SettingsText.DataDescription</p>
        </article>
    </section>
</main>
