@page "/"
@using ExampleAppMAUI.Shared.Services
@inject IFormFactor FormFactor

<PageTitle>@AppIdentityText.Name</PageTitle>

<main class="home-page">
    <section class="home-panel">
        <p>@AppIdentityText.ProfileRole</p>
        <h1>@AppIdentityText.Name</h1>
        <span>@AppIdentityText.Tagline</span>
    </section>

    <section class="home-runtime">
        <span>@factor</span>
        <span>@platform</span>
    </section>
</main>

@code {
    private string factor => FormFactor.GetFormFactor();
    private string platform => FormFactor.GetPlatform();
}
